import math
import help


def create_matrix_fifth_task(
    height: int = 5, width: int = 5
) -> help.Matrix1Based[float]:
    """Створення матриці 5x5 за формулою варіанта 21.

    Args:
        height (int): висота матриці (кількість рядків).
        width (int): ширина матриці (кількість стовпців).

    Returns:
        Matrix1Based[float]: матриця з обчисленими значеннями.
    """
    matrix = help.Matrix1Based[float](height, width)
    for i in range(1, height + 1):
        for j in range(1, width + 1):
            value: float = ((3 + i) / (i + j)) * math.sqrt(i ** 3 + j ** 2) + 2 ** (i - j)
            matrix[i][j] = value
    return matrix


def create_vector_fifth_task(matrix: help.Matrix1Based[float]) -> list[float]:
    """Створення вектора як сум елементів непарних рядків матриці.

    Args:
        matrix (Matrix1Based[float]): матриця-джерело даних.

    Returns:
        list[float]: список сум для рядків 1, 3, 5.
    """
    vector: list[float] = []
    for i in range(1, matrix.rows + 1, 2):
        row_sum: float = 0.0
        for j in range(1, matrix.cols + 1):
            val = matrix[i][j]
            if val is not None:
                row_sum = row_sum + val
        vector.append(row_sum)
    return vector


def print_matrix_fifth_task(matrix: help.Matrix1Based[float]) -> None:
    """Вивід матриці у форматованому вигляді."""
    print()
    print(matrix)


def print_vector_fifth_task(vector: list[float]) -> None:
    """Вивід вектора з трьома знаками після коми."""
    formatted = [f"{item:.3f}" for item in vector]
    print(*formatted)


def fifth_task() -> None:
    """Запуск п'ятого завдання."""
    height, width = 5, 5
    matrix = create_matrix_fifth_task(height, width)
    vector = create_vector_fifth_task(matrix)
    print("Створена матриця:")
    print_matrix_fifth_task(matrix)
    print("\nСтворений вектор:")
    print_vector_fifth_task(vector)


if __name__ == "__main__":
    print("--- Завдання 5 ---")
    fifth_task()
