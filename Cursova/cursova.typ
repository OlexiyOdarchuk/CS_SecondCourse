import math
import help


def second_task(x: float) -> float:
    """Друге завдання — обчислення кусково-заданої функції y(x).

    Args:
        x (float): значення змінної.

    Returns:
        float: значення функції y(x).
    """
    a: float = 3.1
    if x > 1:
        return math.sqrt(a + math.log10(x))
    if abs(x) < 1:
        return math.asin(x)
    return x ** a


if __name__ == "__main__":
