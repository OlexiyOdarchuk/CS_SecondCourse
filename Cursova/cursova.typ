import math
import help


def first_task(x: float, y: float, z: float) -> float | str:
    """Перше завдання — обчислення значення функції f(x, y, z).

    Args:
        x (float): змінна X (має бути додатною для коректного обчислення ln x).
        y (float): змінна Y.
        z (float): змінна Z.

    Returns:
        float | str: результат обчислення або повідомлення про помилку.
    """
    if x <= 0:
        return "Помилка: x має бути більше 0 для обчислення ln(x)"

    t: float = y - z
    numerator: float = y - (z ** (y - z))
    denominator: float = 1 + x ** 2
    ln_x: float = math.log(x)

    f: float = t * (numerator / denominator) + ln_x
    return f


if __name__ == "__main__":
    print("--- Завдання 1 ---")
    data = help.input_variables(float, amount=3)
    result = first_task(*data[0])
    print(f"Результат виконання завдання 1: {result}")
