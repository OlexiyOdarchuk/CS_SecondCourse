import math
import help
from collections.abc import Callable


def for_cycle_third_task(x: float) -> float:
    """Обчислення суми циклом з лічильником (for)."""
    s: float = 0.0
    for k in range(1, 7):
        s = s + math.sin(0.17 * x ** k) / (2 * k + x)
    return s


def while_cycle_third_task(x: float) -> float:
    """Обчислення суми циклом з передумовою (while)."""
    s: float = 0.0
    k: int = 1
    while k < 7:
        s = s + math.sin(0.17 * x ** k) / (2 * k + x)
        k = k + 1
    return s


def while_true_cycle_third_task(x: float) -> float:
    """Обчислення суми циклом з післяумовою (while True + break)."""
    s: float = 0.0
    k: int = 1
    while True:
        s = s + math.sin(0.17 * x ** k) / (2 * k + x)
        k = k + 1
        if k >= 7:
            break
    return s


def third_task(x: float) -> float:
    """Третє завдання — обчислення суми трьома способами та звірка результатів."""
    strategies: list[tuple[str, Callable[[float], float]]] = [
        ("Виконання циклу з лічильником", for_cycle_third_task),
        ("Виконання циклу з передумовою", while_cycle_third_task),
        ("Виконання циклу з післяумовою", while_true_cycle_third_task),
    ]
    results: list[float] = []
    for name, func in strategies:
        value = func(x)
        results.append(value)
        print(f"{name}: {value}")

    for value in results:
        if not math.isclose(value, results[0]):
            raise RuntimeError("Помилка. Результат відрізняється!")

    return results[0]


if __name__ == "__main__":
    print("--- Завдання 3 ---")
    data = help.input_variables(float, amount=1)
    result = third_task(*data[0])
    print(f"Результат виконання завдання 3: {result}")
